# Backend Configuration
PORT=5001
NODE_ENV=development

# MongoDB Connection String
# Local development: mongodb://127.0.0.1:27017/upfront_local
# MongoDB Atlas: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/upfront_local

# Frontend and Admin URLs
FRONTEND_URL=http://localhost:5176
ADMIN_URL=http://localhost:5175
